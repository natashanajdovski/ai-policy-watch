---
import { loadBills, loadRFIs, loadHearings } from '../../lib/load-data';

const { path } = Astro.props as { path: string };

const tabs = [
  { href: '/us-federal/legislation', label: 'Legislation', count: loadBills().length },
  { href: '/us-federal/rfis', label: 'RFIs', count: loadRFIs().length },
  { href: '/us-federal/hearings', label: 'Hearings', count: loadHearings().length },
];

function isActive(href: string) {
  return path === href || path.startsWith(href + '/');
}
---

<nav class="federal-tabs container" aria-label="US Federal sections">
  <ul class="federal-tabs__list">
    {
      tabs.map((t) => (
        <li>
          <a
            href={t.href}
            class:list={['federal-tabs__link', { 'is-active': isActive(t.href) }]}
            aria-current={isActive(t.href) ? 'page' : undefined}
          >
            <span class="federal-tabs__label">{t.label}</span>
            <span class="federal-tabs__count">{t.count}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .federal-tabs {
    border-bottom: var(--border-thin);
    padding-top: var(--sp-4);
  }
  .federal-tabs__list {
    display: flex;
    gap: var(--sp-6);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .federal-tabs__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) 0;
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    color: var(--c-ink-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .federal-tabs__link:hover {
    color: var(--c-ink);
  }
  .federal-tabs__link.is-active {
    color: var(--c-ink);
    border-bottom-color: var(--c-accent);
    font-weight: 500;
  }
  .federal-tabs__count {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 999px;
    background: var(--c-chip-open-bg);
    color: var(--c-chip-open-ink);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
</style>
