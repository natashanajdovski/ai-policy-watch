# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Required: Congress.gov API key
# Get one at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# Optional: Regulations.gov API key
# Used to enrich RFI rows with direct comment-submission links.
# Get one at https://open.gsa.gov/api/regulationsgov/
# Leave blank to skip Regulations.gov enrichment.
REGULATIONS_GOV_API_KEY=
